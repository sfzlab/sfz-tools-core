{
  "name": "@sfz-tools/core",
  "version": "0.0.28",
  "description": "Core library containing shared functionality",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rimraf ./dist && tsc && npm run copy",
    "check": "npm run format && npm run lint && npm run build && npm test",
    "copy": "mkdir -p ./dist/lib && cp -r ./src/lib/* ./dist/lib",
    "dev": "npm run build && node index.js",
    "format": "prettier --write 'src/**/*.{ts,tsx}' && prettier --write 'tests/**/*.{ts,tsx}'",
    "lint": "eslint .",
    "prepare": "npm run build",
    "test": "npm run build && jest --config jestconfig.json --coverage --detectOpenHandles",
    "test:update": "npm run build && jest --config jestconfig.json --updateSnapshot"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kmturley/sfz-tools-core.git"
  },
  "keywords": [
    "sfz",
    "tools",
    "library",
    "core",
    "package"
  ],
  "author": "kmturley",
  "license": "CC0-1.0",
  "bugs": {
    "url": "https://github.com/kmturley/sfz-tools-core/issues"
  },
  "homepage": "https://github.com/kmturley/sfz-tools-core#readme",
  "dependencies": {
    "essentia.js": "^0.1.3",
    "ffmpeg-static": "^5.3.0",
    "fs-extra": "^11.3.3",
    "glob": "^13.0.6",
    "js-yaml": "^4.1.1",
    "node-fetch": "^3.3.2",
    "node-wav": "^0.0.2",
    "nodejs-fs-utils": "^1.2.6",
    "xml-js": "^1.6.11"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.3.0",
    "@types/node-fetch": "^2.6.13",
    "@types/node-wav": "^0.0.4",
    "eslint": "^10.0.1",
    "globals": "^17.3.0",
    "jest": "^30.2.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0"
  }
}
